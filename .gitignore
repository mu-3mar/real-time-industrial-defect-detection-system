# ========================
# GLOBAL IGNORE RULES
# ========================

# Ignore all datasets
data/
**/data/
datasets/
**/datasets/

# Ignore any images / visualizations
*.jpg
*.jpeg
*.png
*.bmp
*.gif
*.webp

# Ignore notebook checkpoints, pycache
__pycache__/
*.pyc
.ipynb_checkpoints/

# Ignore environments
env/
venv/

# Ignore editor folders
.vscode/
.idea/
.history/

# Ignore archives
*.zip
*.tar
*.gz

# Ignore secrets
.env
secrets.json

# ========================
# IGNORE ALL RUNS EXCEPT MODEL FILES
# ========================

**/runs/**

# Allow only model files inside runs
!**/runs/**/*.pt
!**/runs/**/*.onnx
!**/runs/**/*.tflite

# ========================
# BLOCK ANY PRETRAINED YOLO MODELS OUTSIDE RUNS
# ========================

fine-tuning/combine-fine-tuning/box-YOLO/yolov8n.pt
fine-tuning/combine-fine-tuning/box-YOLO/yolo11n.pt
fine-tuning/combine-fine-tuning/defect-YOLO/yolov8n.pt
fine-tuning/combine-fine-tuning/defect-YOLO/yolo11n.pt
