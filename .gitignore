# ========================
# GLOBAL IGNORE RULES
# ========================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.ipynb_checkpoints/

# Environments (keep .env.example for reference)
.env
.env.*
!.env.example
!**/.env.example
Boxes/flow/config/.env
env/
venv/
.venv/

# Datasets and large data
data/
**/data/
datasets/
**/datasets/

# Logs and outputs
logs/
outputs/
*.log

# Media and exports (optional; uncomment if you don't want to track)
# *.jpeg
# *.bmp
# *.gif
# *.webp
# *.mp4
# *.avi
# *.mov
# *.mkv
*.tsv
*.parquet
*.pdf
*.svg
*.eps
*.html

# Secrets and credentials (do not commit)
secrets.json
*.pem
*.key
*.p12
*.pfx

# Firebase: service account keys (private keys) and config with DB URL
Boxes/flow/config/*-firebase-adminsdk*.json
Boxes/flow/config/*credentials*
Boxes/flow/config/firebase-service-account*.json
!Boxes/flow/config/firebase-service-account.example.json
Boxes/flow/config/firebase_config.json
!Boxes/flow/config/firebase_config.json.example
*firebase-adminsdk*.json
**/firebase*adminsdk*.json

# WebRTC TURN secret (webrtc.yaml contains secret)
Boxes/flow/config/webrtc.yaml

# Local overrides that may contain secrets
*local*.yaml
*local*.yml
*secrets*.yaml
*secrets*.yml
config.local.*

# Editor and OS
.vscode/
.idea/
.history/
.DS_Store

# Archives
*.zip
*.tar
*.gz

# Model training artifacts (keep Boxes/flow/models/*.onnx for runtime)
*.tflite
*.npy
*.h5
*.pb
*.index
*.data-00000-of-00001
