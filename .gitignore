# ========================
# GLOBAL IGNORE RULES
# ========================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.ipynb_checkpoints/

# Environments
.env
.env.*
env/
venv/
.venv/

# Datasets and large data
data/
**/data/
datasets/
**/datasets/

# Logs and outputs
logs/
outputs/
*.log

# Media and exports (optional; uncomment if you don't want to track)
# *.jpeg
# *.bmp
# *.gif
# *.webp
# *.mp4
# *.avi
# *.mov
# *.mkv
*.tsv
*.parquet
*.pdf
*.svg
*.eps

# Secrets and credentials (do not commit)
secrets.json
Boxes/flow/config/*.json
Boxes/flow/config/*credentials*
*firebase-adminsdk*.json

# Editor and OS
.vscode/
.idea/
.history/
.DS_Store

# Archives
*.zip
*.tar
*.gz

# Model training artifacts (keep Boxes/flow/models/*.onnx for runtime)
*.tflite
*.npy
*.h5
*.pb
*.index
*.data-00000-of-00001
