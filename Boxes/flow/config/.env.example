## Example environment variables for Boxes/flow
#
# Copy to: Boxes/flow/config/.env
# (This file is optional if you fully configure `firebase.yaml` and `webrtc.yaml`.)

# Firebase (fallback if firebase.yaml omits database_url)
FIREBASE_DATABASE_URL="https://YOUR-PROJECT-default-rtdb.YOUR-REGION.firebasedatabase.app"

# WebRTC TURN (fallback if webrtc.yaml is missing)
TURN_SECRET="YOUR_TURN_SECRET"

# Optional device override (auto|cuda|cpu)
QC_SCM_FLOW_DEVICE="auto"

